    {
      "cell_type": "code",
      "source": [
        "# Requires previous parsed metrics, matrices, and arrays\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"              PERSONALITY DETECTION\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "max_messages = max(message_count.values()) if message_count else 0\n",
        "min_messages = min(message_count.values()) if message_count else 0\n",
        "\n",
        "for person in participants:\n",
        "    total = message_count[person]\n",
        "    row = participant_index[person]\n",
        "\n",
        "    # Night messages count (12 AM to 5 AM inclusive)\n",
        "    night_messages = int(sum(heatmap[row][0:6]))\n",
        "\n",
        "    long_messages = 0\n",
        "    for msg in messages:\n",
        "        if msg[\"sender\"] == person:\n",
        "            if len(msg[\"message\"].split()) >= 15:\n",
        "                long_messages += 1\n",
        "\n",
        "    if total == max_messages:\n",
        "        personality = \"👑 Spam King\"\n",
        "    elif total == min_messages:\n",
        "        personality = \"👻 Ghost\"\n",
        "    elif night_messages >= 20:\n",
        "        personality = \"🌙 Night Owl\"\n",
        "    elif long_messages >= 20:\n",
        "        personality = \"📚 Story Teller\"\n",
        "    elif total >= 500:\n",
        "        personality = \"❤️ Caretaker\"\n",
        "    else:\n",
        "        personality = \"🎭 Drama Queen\"\n",
        "\n",
        "    print(f\"{person:<12} -> {personality}\")"
      ],
      "metadata": {
