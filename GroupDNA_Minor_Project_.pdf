          "text": [
            "============================================================\n",
            "              RESPONSE ANALYSIS\n",
            "============================================================\n",
            "Fastest Replier      : Neha (0 min)\n",
            "Slowest Replier      : Priya (359 min)\n",
            "Average Response Time: 41 min\n",
            "Longest Silent Streak: 5 hours 59 min\n",
            "Most Responsive Pair : Priya ↔ Karan\n"
          ]
        }
      ]
