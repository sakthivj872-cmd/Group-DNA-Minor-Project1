    {
      "cell_type": "code",
      "source": [
        "# Requires 'messages' array from Feature 1 and 'sorted_messages' from Feature 2\n",
        "\n",
        "most_active = sorted_messages[0][0]\n",
        "highest_messages = sorted_messages[0][1]\n",
        "\n",
        "day_count = {}\n",
        "hour_count = {}\n",
        "\n",
        "for msg in messages:\n",
        "    date = msg[\"timestamp\"].split(\",\")[0].strip()\n",
        "    day_count[date] = day_count.get(date, 0) + 1\n",
        "\n",
        "    time_part = msg[\"timestamp\"].split(\",\")[1].strip()\n",
        "    hour = time_part.split(\":\")[0]\n",
        "    hour_count[hour] = hour_count.get(hour, 0) + 1\n",
        "\n",
        "active_day = max(day_count, key=day_count.get)\n",
        "highest_day_messages = day_count[active_day]\n",
        "\n",
        "active_hour = max(hour_count, key=hour_count.get)\n",
        "highest_hour_messages = hour_count[active_hour]\n",
        "\n",
        "print(\"=\" * 50)\n",
        "print(\"           ACTIVITY ANALYSIS\")\n",
        "print(\"=\" * 50)\n",
        "print(\"Most Active Participant :\", most_active)\n",
        "print(\"Messages Sent           :\", highest_messages)\n",
        "print(\"\\nMost Active Day         :\", active_day)\n",
        "print(\"Messages                :\", highest_day_messages)\n",
        "print(\"\\nMost Active Hour        :\", active_hour + f\":00\")\n",
        "print(\"Messages                :\", highest_hour_messages)"
      ],
