    {
      "cell_type": "code",
      "source": [
        "# Requires 'messages' array from Feature 1\n",
        "from collections import Counter\n",
        "\n",
        "words_list = []\n",
        "for msg in messages:\n",
        "    if msg[\"message\"] in [\"<Media omitted>\", \"This message was deleted\"]:\n",
        "        continue\n",
        "    # Standard text normalization\n",
        "    text = msg[\"message\"].lower()\n",
        "    text = text.translate(str.maketrans(\"\", \"\", string.punctuation))\n",
        "    words_list.extend(text.split())\n",
        "\n",
        "word_counts = Counter(words_list)\n",
        "sorted_words = word_counts.most_common()\n",
        "\n",
        "if not sorted_words:\n",
        "    sorted_words = [(\"none\", 1)]\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"        THIS GROUP'S FAVOURITE WORDS\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "max_count = sorted_words[0][1]\n",
        "\n",
        "for word, count in sorted_words[:10]:\n",
        "    bar_length = int((count / max_count) * 20)\n",
        "    if bar_length == 0:\n",
        "        bar_length = 1\n",
        "    bar = \"█\" * bar_length\n",
        "    print(f\"{word:<10} {bar:<20} {count}\")"
      ],
      "metadata": {
        "id": "L7NSdIzq8iT2",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "8043f47c-079b-41d2-847f-cc3e042d61f1"
      },
