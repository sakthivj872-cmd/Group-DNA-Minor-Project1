      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "\n",
            "--- Feature 1: Chat Parser ---\n",
            "Total lines: 3178\n",
            "Total Parsed Messages : 3174\n",
            "System Messages       : 4\n",
            "Media Messages        : 32\n",
            "Deleted Messages      : 15\n",
            "\n",
            "First 5 messages sample:\n",
            "{'timestamp': '01/04/24, 01:17', 'sender': 'Rahul', 'message': 'scene fix'}\n",
            "{'timestamp': '01/04/24, 01:17', 'sender': 'Rahul', 'message': 'haan'}\n",
            "{'timestamp': '01/04/24, 01:18', 'sender': 'Rahul', 'message': 'kya scene'}\n",
            "{'timestamp': '01/04/24, 02:13', 'sender': 'Rahul', 'message': 'abhi free hai?'}\n",
            "{'timestamp': '01/04/24, 02:13', 'sender': 'Rahul', 'message': 'abey'}\n"
          ]
        }
      ],
      "source": [
        "print(\"\\n--- Feature 1: Chat Parser ---\")\n",
        "\n",
        "# Read the chat file\n",
        "# Note: Change this path to match your local file layout if needed\n",
        "with open(\"/content/hostel_bois.txt\", \"r\", encoding=\"utf-8\") as file:\n",
        "    lines = file.readlines()\n",
        "\n",
        "print(\"Total lines:\", len(lines))\n",
        "\n",
        "messages = []\n",
        "system_count = 0\n",
        "media_count = 0\n",
        "deleted_count = 0\n",
        "\n",
        "for line in lines:\n",
        "    line = line.strip()\n",
        "\n",
        "    # Skip empty lines\n",
        "    if line == \"\":\n",
        "        continue\n",
        "\n",
        "    # Skip continuation lines\n",
        "    if len(line) < 8 or line[2] != \"/\" or line[5] != \"/\":\n",
        "        continue\n",
        "\n",
        "    try:\n",
        "        timestamp, rest = line.split(\" - \", 1)\n",
        "        sender, message = rest.split(\": \", 1)\n",
        "    except ValueError:\n",
        "        system_count += 1\n",
        "        continue\n",
        "\n",
        "    # Count media messages\n",
        "    if message == \"<Media omitted>\":\n",
        "        media_count += 1\n",
        "\n",
        "    # Count deleted messages\n",
        "    if message == \"This message was deleted\":\n",
        "        deleted_count += 1\n",
        "\n",
        "    messages.append({\n",
        "        \"timestamp\": timestamp,\n",
        "        \"sender\": sender,\n",
        "        \"message\": message\n",
        "    })\n",
        "\n",
        "# Checking the result\n",
        "print(\"Total Parsed Messages :\", len(messages))\n",
        "print(\"System Messages       :\", system_count)\n",
        "print(\"Media Messages        :\", media_count)\n",
        "print(\"Deleted Messages      :\", deleted_count)\n",
        "\n",
        "print(\"\\nFirst 5 messages sample:\")\n",
        "for message in messages[:5]:\n",
        "    print(message)\n"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Requires 'messages' array from Feature 1\n",
        "\n",
        "message_count = {}\n",
        "for msg in messages:\n",
        "    sender = msg[\"sender\"]\n",
        "    message_count[sender] = message_count.get(sender, 0) + 1\n",
        "\n",
        "participants = list(message_count.keys())\n",
        "participant_index = {person: i for i, person in enumerate(participants)}\n",
        "total_messages = len(messages)\n",
        "\n",
        "# Splitting correctly to fetch the date part instead of the timestamp's time string\n",
        "first_date = messages[0][\"timestamp\"].split(\",\")[0].strip()\n",
        "last_date = messages[-1][\"timestamp\"].split(\",\")[0].strip()\n",
        "\n",
        "sorted_messages = sorted(message_count.items(), key=lambda x: x[1], reverse=True)\n",
        "\n",
        "print(\"=\" * 50)\n",
        "print(\"            GROUP OVERVIEW\")\n",
        "print(\"=\" * 50)\n",
        "print(\"Group Name      : Hostel Bois 4ever\")\n",
        "print(\"First Date      :\", first_date)\n",
        "print(\"Last Date       :\", last_date)\n",
        "print(\"Total Messages  :\", total_messages)\n",
        "print(\"Participants    :\", len(participants))\n",
        "print(\"\\nMessages Per Person\")\n",
        "print(\"-\" * 50)\n",
        "for person, count in sorted_messages:\n",
        "    percentage = (count / total_messages) * 100\n",
        "    print(f\"{person:<10} : {count:>4} ({percentage:.1f}%)\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
