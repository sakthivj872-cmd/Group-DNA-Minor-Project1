    {
      "cell_type": "code",
      "source": [
        "from datetime import datetime\n",
        "\n",
        "# Parse explicit datetimes\n",
        "for msg in messages:\n",
        "    msg[\"datetime\"] = datetime.strptime(msg[\"timestamp\"].strip(), \"%d/%m/%y, %H:%M\")\n",
        "\n",
        "response_data = []\n",
        "\n",
        "for i in range(1, len(messages)):\n",
        "    previous = messages[i - 1]\n",
        "    current = messages[i]\n",
        "\n",
        "    # Ignore consecutive messages from the exact same person\n",
        "    if previous[\"sender\"] == current[\"sender\"]:\n",
        "        continue\n",
        "\n",
        "    difference = current[\"datetime\"] - previous[\"datetime\"]\n",
        "    minutes = difference.total_seconds() / 60\n",
        "\n",
        "    if minutes >= 0:\n",
        "        response_data.append({\n",
        "            \"sender\": current[\"sender\"],\n",
        "            \"previous_sender\": previous[\"sender\"],\n",
        "            \"minutes\": minutes\n",
        "        })\n",
        "\n",
        "if response_data:\n",
        "    fastest = min(response_data, key=lambda x: x[\"minutes\"])\n",
        "    slowest = max(response_data, key=lambda x: x[\"minutes\"])\n",
        "\n",
        "    total_minutes = sum(item[\"minutes\"] for item in response_data)\n",
        "    average_minutes = total_minutes / len(response_data)\n",
        "\n",
        "    pair_count = {}\n",
        "    for item in response_data:\n",
        "        pair = item[\"previous_sender\"] + \" ↔ \" + item[\"sender\"]\n",
        "        pair_count[pair] = pair_count.get(pair, 0) + 1\n",
        "    best_pair = max(pair_count, key=pair_count.get)\n",
        "else:\n",
        "    fastest = {\"sender\": \"N/A\", \"minutes\": 0}\n",
        "    slowest = {\"sender\": \"N/A\", \"minutes\": 0}\n",
        "    average_minutes = 0\n",
        "    best_pair = \"N/A\"\n",
        "\n",
        "avg_hours = int(average_minutes // 60)\n",
        "avg_minutes = int(average_minutes % 60)\n",
        "gap = slowest[\"minutes\"]\n",
        "\n",
        "days = int(gap // (24 * 60))\n",
        "gap %= (24 * 60)\n",
        "hours = int(gap // 60)\n",
        "minutes = int(gap % 60)\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"              RESPONSE ANALYSIS\")\n",
        "print(\"=\" * 60)\n",
        "print(f\"Fastest Replier      : {fastest['sender']} ({fastest['minutes']:.0f} min)\")\n",
        "print(f\"Slowest Replier      : {slowest['sender']} ({slowest['minutes']:.0f} min)\")\n",
        "\n",
        "if avg_hours > 0:\n",
        "    print(f\"Average Response Time: {avg_hours} hr {avg_minutes} min\")\n",
        "else:\n",
        "    print(f\"Average Response Time: {avg_minutes} min\")\n",
        "\n",
        "if days > 0:\n",
        "    silent = f\"{days} days {hours} hours\"\n",
        "elif hours > 0:\n",
        "    silent = f\"{hours} hours {minutes} min\"\n",
        "else:\n",
        "    silent = f\"{minutes} min\"\n",
        "\n",
        "print(f\"Longest Silent Streak: {silent}\")\n",
        "print(f\"Most Responsive Pair : {best_pair}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
