    {
      "cell_type": "code",
      "source": [
        "# Requires 'messages' and 'participants' / 'participant_index' mappings from prior features\n",
        "\n",
        "# Rows = participants, Columns = 24 hours\n",
        "heatmap = np.zeros((len(participants), 24))\n",
        "\n",
        "for msg in messages:\n",
        "    sender = msg[\"sender\"]\n",
        "    time_part = msg[\"timestamp\"].split(\",\")[1].strip()\n",
        "    hour = int(time_part.split(\":\")[0])\n",
        "\n",
        "    row_idx = participant_index[sender]\n",
        "    heatmap[row_idx][hour] += 1\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"ACTIVITY HEATMAP (messages by hour)\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "display_hours = [0, 3, 6, 9, 12, 15, 18, 21]\n",
        "\n",
        "print(\" \" * 10, end=\"\")\n",
        "for h in display_hours:\n",
        "    print(f\"{h:02}\", end=\"  \")\n",
        "print()\n",
        "\n",
        "for i in range(len(participants)):\n",
        "    print(f\"{participants[i]:<8}\", end=\" \")\n",
        "    max_value = np.max(heatmap[i])\n",
        "\n",
        "    for h in display_hours:\n",
        "        value = heatmap[i][h]\n",
        "        if max_value == 0:\n",
        "            symbol = \".\"\n",
        "        else:\n",
        "            ratio = value / max_value\n",
        "            if ratio == 0:\n",
        "                symbol = \".\"\n",
        "            elif ratio <= 0.25:\n",
        "                symbol = \"░\"\n",
        "            elif ratio <= 0.50:\n",
        "                symbol = \"▒\"\n",
        "            else:\n",
        "                symbol = \"█\"\n",
        "        print(symbol, end=\"   \")\n",
        "    print()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "31396471-5ca1-476a-e2d8-4383a19c965b",
